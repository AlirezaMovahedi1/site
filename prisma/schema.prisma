// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String
  specs       String      // Store specs as JSON string
  price       Float
  image       String
  type        String      // "PHYSICAL" or "DIGITAL"
  downloadUrl String?     // for digital products
  inventory   Int?        // for physical products
  rating      Float       @default(5.0)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String?     // Nullable for digital-only orders
  totalAmount     Float
  isPaid          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  summary   String
  content   String
  image     String
  readTime  String   // e.g. "5 min read"
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Hashed password
  name      String?
  createdAt DateTime @default(now())
}

model Ticket {
  id         String   @id @default(uuid())
  name       String
  phone      String
  department String
  message    String
  status     String   @default("new") // new, progress, success, cancel
  createdAt  DateTime @default(now())
}
